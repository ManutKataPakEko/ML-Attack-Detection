# Attack Detection Service Configuration
# Copy this file to .env and update values for your environment
# This is used for LOCAL DEVELOPMENT ONLY
# For Docker, use docker-compose.yaml environment variables instead

# ========== Model & Data Configuration ==========
# Path to trained model pickle file
MODEL_PATH=models/best_model.pkl

# Directory containing processed training data
PROCESSED_DATA_DIR=data/processed/v0.1.1

# ========== Server Configuration ==========
# gRPC server port (must match docker-compose if using docker)
GRPC_PORT=50051

# Number of gRPC worker threads
GRPC_WORKERS=10

# REST API port
REST_PORT=8000

# REST API host (0.0.0.0 for docker, 127.0.0.1 for local)
REST_HOST=0.0.0.0

# Enable auto-reload for REST API (only in development!)
REST_RELOAD=false

# ========== Database Configuration ==========
# SQLite for local development
DATABASE_URL=sqlite:///./data/predictions.db

# PostgreSQL for production (use with docker-compose)
# DATABASE_URL=postgresql://postgres:secret@localhost:5432/attack_detection

# ========== Logging Configuration ==========
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Directory for log files
LOG_DIR=logs

# ========== Environment ==========
# Set to 'production' for production environment
ENV=development

# Python path
PYTHONPATH=./src
